                        "dataType": "Object",
                        "isNullable": true,
                        "direction": "in"
                    },
                    "emailAddress": {
                        "dataType": "String",
                        "isNullable": false,
                        "direction": "in",
                        "access": "visible",
                        "value": "{{Contact.Default.Email}}"
                    },
                    "contactKey": {
                        "dataType": "String",
                        "isNullable": false,
                        "direction": "in",
                        "value": "{{Contact.Key}}"
                    }
                }
            ],
            "outArguments": [
